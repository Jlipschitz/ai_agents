{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jlipschitz/ai_agents/agent-coordination.schema.json",
  "title": "AI Agents coordination config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "configVersion": {
      "type": "integer",
      "minimum": 1
    },
    "extends": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/stringArray"
        }
      ]
    },
    "projectName": {
      "type": "string",
      "minLength": 1
    },
    "agentIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "docs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "roots": {
          "$ref": "#/$defs/stringArray"
        },
        "appNotes": {
          "type": "string"
        },
        "visualWorkflow": {
          "type": "string"
        },
        "apiPrefixes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowMainBranchClaims": {
          "type": "boolean"
        },
        "allowDetachedHead": {
          "type": "boolean"
        },
        "allowedBranchPatterns": {
          "$ref": "#/$defs/stringArray"
        },
        "defaultBaseBranch": {
          "type": "string"
        },
        "staleBranchDays": {
          "type": "integer",
          "minimum": 0
        },
        "protectedBranchPatterns": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "capacity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "maxActiveTasksPerAgent": {
          "type": "integer",
          "minimum": 1
        },
        "maxBlockedTasksPerAgent": {
          "type": "integer",
          "minimum": 0
        },
        "preferredDomainsByAgent": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/stringArray"
          }
        },
        "enforcePreferredDomains": {
          "type": "boolean"
        }
      }
    },
    "conflictPrediction": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "blockOnGitOverlap": {
          "type": "boolean"
        }
      }
    },
    "ownership": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "codeownersFiles": {
          "$ref": "#/$defs/stringArray"
        },
        "broadPathPatterns": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "policyEnforcement": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "enum": [
            "warn",
            "block"
          ]
        },
        "rules": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "broadClaims": {
              "type": "boolean"
            },
            "codeownersCrossing": {
              "type": "boolean"
            },
            "finishRequiresApproval": {
              "type": "boolean"
            },
            "finishRequiresDocsReview": {
              "type": "boolean"
            },
            "finishApprovalScope": {
              "type": "string"
            }
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "enum": [
            "standard",
            "redacted",
            "local-only"
          ]
        },
        "offline": {
          "type": "boolean"
        }
      }
    },
    "monorepo": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "workspaceRoots": {
          "$ref": "#/$defs/stringArray"
        },
        "partialCheckout": {
          "type": "boolean"
        },
        "fallbackRoot": {
          "type": "string"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sharedRisk": {
          "$ref": "#/$defs/stringArray"
        },
        "visualSuite": {
          "$ref": "#/$defs/stringArray"
        },
        "visualSuiteDefault": {
          "$ref": "#/$defs/stringArray"
        },
        "visualImpact": {
          "$ref": "#/$defs/stringArray"
        },
        "visualImpactFiles": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "visualRequiredChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "visualSuiteUpdateChecks": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "roots": {
          "$ref": "#/$defs/stringArray"
        },
        "keepDays": {
          "type": "integer",
          "minimum": 1
        },
        "keepFailedDays": {
          "type": "integer",
          "minimum": 1
        },
        "maxMb": {
          "type": "integer",
          "minimum": 1
        },
        "protectPatterns": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "command": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1000
          },
          "artifactRoots": {
            "$ref": "#/$defs/stringArray"
          },
          "requiredForPaths": {
            "$ref": "#/$defs/stringArray"
          },
          "requireArtifacts": {
            "type": "boolean"
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "categories": {
          "$ref": "#/$defs/stringArray"
        },
        "sectionHeading": {
          "type": "string"
        }
      }
    },
    "onboarding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "string"
        },
        "profiles": {
          "$ref": "#/$defs/stringArray"
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "id",
              "paths"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string"
              },
              "paths": {
                "$ref": "#/$defs/stringArray"
              },
              "required": {
                "type": "boolean"
              },
              "recommendation": {
                "type": "string"
              },
              "profile": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "pathClassification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "productPrefixes": {
          "$ref": "#/$defs/stringArray"
        },
        "dataPrefixes": {
          "$ref": "#/$defs/stringArray"
        },
        "verifyPrefixes": {
          "$ref": "#/$defs/stringArray"
        },
        "docsPrefixes": {
          "$ref": "#/$defs/stringArray"
        },
        "docsFiles": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "planning": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultDomains": {
          "$ref": "#/$defs/stringArray"
        },
        "productFallbackPaths": {
          "$ref": "#/$defs/stringArray"
        },
        "dataFallbackPaths": {
          "$ref": "#/$defs/stringArray"
        },
        "verifyFallbackPaths": {
          "$ref": "#/$defs/stringArray"
        },
        "docsFallbackPaths": {
          "$ref": "#/$defs/stringArray"
        },
        "agentSizing": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "minAgents": {
              "type": "integer",
              "minimum": 1
            },
            "maxAgents": {
              "type": "integer",
              "minimum": 1
            },
            "mediumComplexityScore": {
              "type": "integer",
              "minimum": 1
            },
            "largeComplexityScore": {
              "type": "integer",
              "minimum": 1
            },
            "productKeywords": {
              "$ref": "#/$defs/stringArray"
            },
            "dataKeywords": {
              "$ref": "#/$defs/stringArray"
            },
            "verifyKeywords": {
              "$ref": "#/$defs/stringArray"
            },
            "docsKeywords": {
              "$ref": "#/$defs/stringArray"
            }
          }
        }
      }
    },
    "domainRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "keywords",
          "scopes"
        ],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "keywords": {
            "$ref": "#/$defs/stringArray"
          },
          "scopes": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "product": {
                "$ref": "#/$defs/stringArray"
              },
              "data": {
                "$ref": "#/$defs/stringArray"
              },
              "verify": {
                "$ref": "#/$defs/stringArray"
              },
              "docs": {
                "$ref": "#/$defs/stringArray"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "projectName",
    "agentIds",
    "docs",
    "paths",
    "verification",
    "pathClassification",
    "planning",
    "domainRules"
  ],
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
